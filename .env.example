# ── Required ──────────────────────────────────────────────────────────────
# Powers all pipeline stages
ANTHROPIC_API_KEY=

# Auth for /api/cron/* and /api/pipeline/* (any random string)
CRON_SECRET=

# Vercel KV — auto-set by the Vercel KV integration
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=

# ── Optional ──────────────────────────────────────────────────────────────
# Your deployed URL (used as link in social posts)
NEXT_PUBLIC_SITE_URL=

# ── X (Twitter) ───────────────────────────────────────────────────────────
# https://developer.x.com → Project → Keys & Tokens
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# ── Meta (Facebook + Instagram) ───────────────────────────────────────────
# https://developers.facebook.com → My Apps
META_PAGE_ACCESS_TOKEN=
META_PAGE_ID=
META_IG_USER_ID=
META_AD_ACCOUNT_ID=

# ── TikTok ────────────────────────────────────────────────────────────────
# https://developers.tiktok.com
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# ── LinkedIn ──────────────────────────────────────────────────────────────
# https://www.linkedin.com/developers/
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=

# ── Google Ads ────────────────────────────────────────────────────────────
# https://ads.google.com → Tools → API Center
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
